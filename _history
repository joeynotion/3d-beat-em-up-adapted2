value><value name=\"value\"><shadow type=\"math_number\"><field name=\"NUM\">100</field></shadow></value><next><block type=\"game_control_sprite\"><mutation xmlns=\"http://www.w3.org/1999/xhtml\" _expanded=\"2\" _input_init=\"true\"></mutation><value name=\"sprite\"><block type=\"variables_get\"><field name=\"VAR\" id=\"_Z9X1SEN/?}Me*6Ig!rm\">tinyBlueOx</field></block></value><value name=\"vx\"><shadow type=\"spriteSpeedPicker\"><field name=\"speed\">50</field></shadow></value><value name=\"vy\"><shadow type=\"spriteSpeedPicker\"><field name=\"speed\">50</field></shadow></value><next><block type=\"camerafollow\"><value name=\"sprite\"><block type=\"variables_get\"><field name=\"VAR\" id=\"_Z9X1SEN/?}Me*6Ig!rm\">tinyBlueOx</field></block></value><next><block type=\"set_current_tilemap\"><value name=\"tilemap\"><shadow type=\"tiles_tilemap_editor\"><field name=\"tilemap\">tilemap`level2`</field><data>{\"commentRefs\":[],\"fieldData\":{\"tilemap\":\"level2\"}}</data></shadow></value><next><block type=\"variables_set\"><field name=\"VAR\" id=\"w%Qj6F.#z:[ZzcrD8TS8\">textSprite</field><value name=\"VALUE\"><shadow type=\"math_number\"><field name=\"NUM\">0</field></shadow><block type=\"textsprite_create\"><mutation xmlns=\"http://www.w3.org/1999/xhtml\" _expanded=\"2\" _input_init=\"true\"></mutation><value name=\"text\"><shadow type=\"text\"><field name=\"TEXT\"></field></shadow></value><value name=\"fg\"><shadow type=\"colorindexpicker\"><field name=\"index\">1</field></shadow></value><value name=\"bg\"><shadow type=\"colorindexpicker\"><field name=\"index\">0</field></shadow></value></block></value><next><block type=\"typescript_statement\"><mutation xmlns=\"http://www.w3.org/1999/xhtml\" line0=\"Rendering.updateDepthOrdering()\" numlines=\"1\"></mutation></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></statement></block></xml>","main.ts":"namespace SpriteKind {\n    export const physicalObject = SpriteKind.create()\n    export const Pushable = SpriteKind.create()\n}\n\n// Game Configuration Constants\nnamespace GameConfig {\n    export const GRAVITY = 2\n    export const JUMP_POWER = -14\n    export const PLAYER_SPEED_X = 85\n    export const PLAYER_SPEED_Y = 60\n    export const BOOST_SPEED_X = 120\n    export const BOOST_SPEED_Y = 80\n    export const PUSH_SPEED = 40\n    export const PUSH_THRESHOLD = 6\n    export const FALL_OFFSET = 4\n    export const COLLISION_BUFFER = 2\n    export const DEFAULT_GROUND_LEVEL = 87\n    export const TILE_SIZE = 16\n}\n\n// Game State\nnamespace GameState {\n    export let isJumping = false\n    export let isOnObject = false\n    export let isFallingBehindRock = false\n    export let currentGroundLevel = GameConfig.DEFAULT_GROUND_LEVEL\n    export let verticalVelocity = 0\n    export let isBoosting = false\n}\n\n// Game Objects\nlet tinyBlueOx: Sprite\nlet tree: Sprite\nlet rock: Sprite\nlet textSprite: TextSprite\n\n// Utility Functions\nnamespace Utils {\n    export function getTilemapWidth(): number {\n        // Use a large boundary - adjust based on your actual tilemap size\n        return 800  // You can adjust this to match your tilemap width\n    }\n\n    export function getTilemapHeight(): number {\n        // Use a large boundary - adjust based on your actual tilemap size\n        return 600  // You can adjust this to match your tilemap height\n    }\n\n    export function isWithinBounds(sprite: Sprite, newX: number, newY: number): boolean {\n        const halfWidth = sprite.width / 2\n        const halfHeight = sprite.height / 2\n\n        return newX - halfWidth >= 0 &&\n            newX + halfWidth <= getTilemapWidth() &&\n            newY - halfHeight >= 0 &&\n            newY + halfHeight <= getTilemapHeight()\n    }\n}\n\n// Physics System\nnamespace Physics {\n    export function applyJumpPhysics(): void {\n        if (GameState.isJumping || GameState.isFallingBehindRock) {\n            GameState.verticalVelocity += GameConfig.GRAVITY\n            tinyBlueOx.y += GameState.verticalVelocity\n\n            // Check for landing\n            if (tinyBlueOx.bottom >= GameState.currentGroundLevel) {\n                tinyBlueOx.bottom = GameState.currentGroundLevel\n                GameState.verticalVelocity = 0\n                GameState.isJumping = false\n                GameState.isFallingBehindRock = false\n                GameState.isOnObject = false\n            }\n        }\n    }\n\n    export function handleJump(): void {\n        if (!GameState.isJumping) {\n            GameState.isJumping = true\n            GameState.isOnObject = false\n            GameState.currentGroundLevel = tinyBlueOx.bottom\n            GameState.verticalVelocity = GameConfig.JUMP_POWER\n        }\n    }\n\n    export function updateMovementSpeed(): void {\n        if (GameState.isBoosting) {\n            controller.moveSprite(tinyBlueOx, GameConfig.BOOST_SPEED_X, GameConfig.BOOST_SPEED_Y)\n        } else {\n            controller.moveSprite(tinyBlueOx, GameConfig.PLAYER_SPEED_X, GameConfig.PLAYER_SPEED_Y)\n        }\n    }\n}\n\n// Collision System\nnamespace Collision {\n    export function preventWalkThrough(player: Sprite, obstacle: Sprite): void {\n        if (!player.overlapsWith(obstacle)) return\n\n        const buffer = GameConfig.COLLISION_BUFFER\n\n        if (player.bottom > obstacle.bottom) {\n            if (player.bottom - obstacle.bottom < buffer) {\n                player.bottom = obstacle.bottom + buffer\n            }\n        } else {\n            if (obstacle.bottom - player.bottom < buffer) {\n                player.bottom = obstacle.bottom - buffer\n            }\n        }\n    }\n\n    export function checkLandingOnObjects(): void {\n        if (GameState.isFallingBehindRock) return\n\n        if (tinyBlueOx.overlapsWith(rock) &&\n            GameState.verticalVelocity > 0 &&\n            tinyBlueOx.bottom >= rock.top) {\n\n            tinyBlueOx.bottom = rock.top\n            GameState.verticalVelocity = 0\n            GameState.isJumping = false\n            GameState.isOnObject = true\n            GameState.currentGroundLevel = rock.top\n        }\n    }\n\n    export function checkForFallingOffObjects(): void {\n        if (!GameState.isOnObject) return\n\n        // Check if player moved off the rock in any direction (left, right, or front)\n        if (tinyBlueOx.x < rock.left ||\n            tinyBlueOx.x > rock.right ||\n            tinyBlueOx.y > rock.bottom) {  // Added front falling (when y > rock.bottom)\n\n            GameState.isJumping = true\n            GameState.isOnObject = false\n            GameState.verticalVelocity = 0\n            // Fall to the rock's bottom level, not the default ground level\n            GameState.currentGroundLevel = rock.bottom - GameConfig.FALL_OFFSET\n        }\n    }\n\n    export function checkForFallingBehindRock(): void {\n        if (!GameState.isOnObject) return\n\n        // If player moves up off the rock\n        if (controller.up.isPressed() && tinyBlueOx.y < rock.top) {\n            GameState.isJumping = false\n            GameState.isOnObject = false\n            GameState.isFallingBehindRock = true\n            GameState.verticalVelocity = 2\n            GameState.currentGroundLevel = rock.bottom - GameConfig.FALL_OFFSET\n        }\n    }\n}\n\n// Rock Pushing System\nnamespace RockPushing {\n    export function handleRockPush(): void {\n        if (!tinyBlueOx.overlapsWith(rock)) return\n\n        let rockMoved = false\n        const pushAmount = GameConfig.PUSH_SPEED / 60\n\n        // Much more lenient alignment check - allows pushing from a wider area\n        const horizontalAlignment = Math.abs(tinyBlueOx.x - rock.x) < rock.width + GameConfig.PUSH_THRESHOLD\n        const verticalAlignment = Math.abs(tinyBlueOx.y - rock.y) < rock.height + GameConfig.PUSH_THRESHOLD\n\n        // Vertical pushing (up/down) - check if player is horizontally aligned\n        if (horizontalAlignment) {\n            if (controller.up.isPressed()) {\n                const newY = rock.y - pushAmount\n                if (Utils.isWithinBounds(rock, rock.x, newY)) {\n                    rock.y = newY\n                    rockMoved = true\n                }\n            }\n            if (controller.down.isPressed()) {\n                const newY = rock.y + pushAmount\n                if (Utils.isWithinBounds(rock, rock.x, newY)) {\n                    rock.y = newY\n                    rockMoved = true\n                }\n            }\n        }\n\n        // Horizontal pushing (left/right) - check if player is vertically aligned\n        if (verticalAlignment) {\n            if (controller.left.isPressed()) {\n                const newX = rock.x - pushAmount\n                if (Utils.isWithinBounds(rock, newX, rock.y)) {\n                    rock.x = newX\n                    rockMoved = true\n                }\n            }\n            if (controller.right.isPressed()) {\n                const newX = rock.x + pushAmount\n                if (Utils.isWithinBounds(rock, newX, rock.y)) {\n                    rock.x = newX\n                    rockMoved = true\n                }\n            }\n        }\n\n        // Only restrict player movement slightly when actively pushing\n        if (rockMoved) {\n            // Instead of locking position completely, just slow down the player slightly\n            // This prevents the \"sticking\" feeling while still keeping them near the rock\n            const playerSpeed = GameState.isBoosting ? 0.3 : 0.5\n\n            if (controller.up.isPressed() && horizontalAlignment) {\n                tinyBlueOx.y -= pushAmount * playerSpeed\n            }\n            if (controller.down.isPressed() && horizontalAlignment) {\n                tinyBlueOx.y += pushAmount * playerSpeed\n            }\n            if (controller.left.isPressed() && verticalAlignment) {\n                tinyBlueOx.x -= pushAmount * playerSpeed\n            }\n            if (controller.right.isPressed() && verticalAlignment) {\n                tinyBlueOx.x += pushAmount * playerSpeed\n            }\n        }\n    }\n}\n\n// Rendering System\nnamespace Rendering {\n    export function updateDepthOrdering(): void {\n        tinyBlueOx.z = tinyBlueOx.bottom\n        rock.z = rock.bottom\n        tree.z = tree.bottom\n    }\n}\n\n// Debug System\nnamespace Debug {\n    export function updateDebugDisplay(): void {\n        const debugInfo = `Rock Y: ${Math.round(rock.y)}`\n        textSprite.setText(debugInfo)\n    }\n}\n\n// Game Initialization\nfunction initializeGame(): void {\n    // Create sprites\n    tree = sprites.create(assets.image`myImage`, SpriteKind.physicalObject)\n    tree.setPosition(44, 87)\n\n    rock = sprites.create(assets.image`myImage0`, SpriteKind.Pushable)\n    rock.setPosition(118, 87)\n\n    tinyBlueOx = sprites.create(assets.image`myImage1`, SpriteKind.Player)\n    tinyBlueOx.setPosition(108, 86)\n    tinyBlueOx.z = 100\n\n    // Set up controls\n    controller.moveSprite(tinyBlueOx, GameConfig.PLAYER_SPEED_X, GameConfig.PLAYER_SPEED_Y)\n\n    // Set up camera and scene\n    scene.cameraFollowSprite(tinyBlueOx)\n    tiles.setCurrentTilemap(tilemap`level2`)\n\n    // Create debug display\n    textSprite = textsprite.create(\"\", 0, 1)\n\n    // Initialize depth ordering\n    Rendering.updateDepthOrdering()\n}\n\n// Event Handlers\ncontroller.A.onEvent(ControllerButtonEvent.Pressed, function () {\n    Physics.handleJump()\n})\n\ncontroller.B.onEvent(ControllerButtonEvent.Pressed, function () {\n    GameState.isBoosting = true\n    Physics.updateMovementSpeed()\n})\n\ncontroller.B.onEvent(ControllerButtonEvent.Released, function () {\n    GameState.isBoosting = false\n    Physics.updateMovementSpeed()\n})\n\n// Main Game Loop\ngame.onUpdate(function () {\n    // Physics\n    Physics.applyJumpPhysics()\n\n    // Collision Detection\n    Collision.checkLandingOnObjects()\n    Collision.checkForFallingOffObjects()\n    Collision.checkForFallingBehindRock()\n\n    // Rock Interaction\n    RockPushing.handleRockPush()\n","README.md":" ","tilemap.g.jres":"{\n    \"transparency16\": {\n        \"data\": \"hwQQABAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA==\",\n        \"mimeType\": \"image/x-mkcd-f4\",\n        \"tilemapTile\": true\n    },\n    \"level2\": {\n        \"id\": \"level2\",\n        \"mimeType\": \"application/mkcd-tilemap\",\n        \"data\": \"\",\n        \"tileset\": [\n            \"myTiles.transparency16\",\n            \"sprites.castle.tileGrass1\",\n            \"sprites.castle.tilePath8\"\n        ],\n        \"displayName\": \"level2\"\n    },\n    \"*\": {\n        \"mimeType\": \"image/x-mkcd-f4\",\n        \"dataEncoding\": \"base64\",\n        \"namespace\": \"myTiles\"\n    }\n}","tilemap.g.ts":"","images.g.jres":"{\n    \"image1\": {\n        \"data\": \"\",\n        \"mimeType\": \"image/x-mkcd-f4\",\n        \"displayName\": \"myImage\"\n    },\n    \"image3\": {\n        \"data\": \"hwQNABAAAAAA8P//AAAAAPD/zP//AAAA8P/P7/7v/gD////v9E7kD//P/P/uTuT////8v0Hu/v//////T35n///87+5EfmcP8M//7kR/Zw/w//z/////AAD//P8AAAAAAAD/DwAAAAAAAP8AAAAAAA==\",\n        \"mimeType\": \"image/x-mkcd-f4\",\n        \"displayName\": \"myImage1\"\n    },\n    \"image2\": {\n        \"data\": \"hwQYABAAAAAAAAAAAAAAAAAAAAAAAAAAAGAAAAAAAAAAdgYAAAAAAGB3BgAAAAAAdmcIAAAAAAB+5szu7u6+AG7m7u7u7u4L7nZ37u7u7r7udnfu7u7u7u5+5u7u7u7u7n7o7u7u7u7ufuju7u7u7u5+5u7u7u7u7nZn7u7u7u7ud3fu7u7uvuxm6O7u7u4Lbmbo7u7uvgB2dwYAAAAAAGB3BgAAAAAAAHYGAAAAAAAAYAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=\",\n        \"mimeType\": \"image/x-mkcd-f4\",\n        \"displayName\": \"myImage0\"\n    },\n    \"*\": {\n        \"mimeType\": \"image/x-mkcd-f4\",\n        \"dataEncoding\": \"base64\",\n        \"namespace\": \"myImages\"\n    }\n}","images.g.ts":"","main.py":"@namespace\nclass SpriteKind:\n    physicalObject = SpriteKind.create()\n    Pushable = SpriteKind.create()\n\"\"\"\n\nMovement & jump variables\n\n\"\"\"\n\"\"\"\n\nDeclare variables\n\n\"\"\"\ndef dontWalkThroughTree():\n    if tinyBlueOx.overlaps_with(tree):\n        if tinyBlueOx.bottom > tree.bottom:\n            if tinyBlueOx.bottom - tree.bottom < 2:\n                tinyBlueOx.bottom = tree.bottom + 2\n        else:\n            if tree.bottom - tinyBlueOx.bottom < 2:\n                tinyBlueOx.bottom = tree.bottom - 2\n# Jump function\n\ndef on_a_pressed():\n    global isJumping, isOnObject, currentGroundLevel, vy\n    if not (isJumping):\n        isJumping = True\n        # Prevent sticking to an object\n        isOnObject = False\n        # Store the height before jumping\n        currentGroundLevel = tinyBlueOx.bottom\n        vy = jumpPower\ncontroller.A.on_event(ControllerButtonEvent.PRESSED, on_a_pressed)\n\n# **NEW: Rock Pushing (Fixed Side Pushing & Prevented Sliding)**\ndef pushRock():\n    global pushSpeed, originalX, originalY, rockMoved\n    if tinyBlueOx.overlaps_with(rock):\n        # The rock moves at a slower speed than the player\n        pushSpeed = 40\n        # Track if the rock moved\n        # **Temporarily disable collision blocking while pushing**\n        originalX = tinyBlueOx.x\n        originalY = tinyBlueOx.y\n        # **Vertical Pushing (Up/Down)**\n        if abs(tinyBlueOx.z - rock.z) < pushThreshold:\n            if controller.up.is_pressed() and rock.top - pushSpeed / 60 > 0:\n                rock.y -= pushSpeed / 60\n                rockMoved = True\n            if controller.down.is_pressed() and rock.bottom + pushSpeed / 60 < scene.screen_height():\n                rock.y += pushSpeed / 60\n                rockMoved = True\n        # **Horizontal Pushing (Left/Right)**\n        if abs(tinyBlueOx.y - rock.y) < rock.height / 2 + pushThreshold:\n            if controller.left.is_pressed() and rock.left - pushSpeed / 60 > 0:\n                rock.x -= pushSpeed / 60\n                rockMoved = True\n            if controller.right.is_pressed() and rock.right + pushSpeed / 60 < scene.screen_width():\n                rock.x += pushSpeed / 60\n                rockMoved = True\n        # **Prevent Player From Sliding Off the Rock**\n        if rockMoved:\n            # Keep player against the rock\n            tinyBlueOx.x = originalX\n            # Prevent unintended movement away from the rock\n            tinyBlueOx.y = originalY\n# **Landing on objects dynamically updates where the player stands**\ndef checkLandingOnObjects():\n    global vy, isJumping, isOnObject, currentGroundLevel\n    if not (isFallingBehindRock) and tinyBlueOx.overlaps_with(rock) and vy > 0 and tinyBlueOx.bottom >= rock.top:\n        tinyBlueOx.bottom = rock.top\n        vy = 0\n        isJumping = False\n        # Mark that the player is standing on an object\n        isOnObject = True\n        # Update ground level to the rock height\n        currentGroundLevel = rock.top\n# **Properly Drop Off the Back of the Rock Without Re-Locking**\ndef checkForFallingBehindRock():\n    global isJumping, isOnObject, isFallingBehindRock, vy, currentGroundLevel\n    if isOnObject:\n        # If the player moves up off the rock\n        if controller.up.is_pressed() and tinyBlueOx.y < rock.top:\n            # Disable jump logic\n            isJumping = False\n            # Make sure they are no longer \"on\" the rock\n            isOnObject = False\n            # NEW: Mark as falling behind the rock\n            isFallingBehindRock = True\n            # Apply small downward force immediately\n            vy = 2\n            # Set smooth transition height\n            currentGroundLevel = rock.bottom - fallOffset\n# Gravity & jumping logic\ndef applyJumpPhysics():\n    global vy, isJumping, isFallingBehindRock, isOnObject\n    if isJumping or isFallingBehindRock:\n        vy += gravity\n        tinyBlueOx.y += vy\n        # Stop falling when reaching stored ground level\n        if tinyBlueOx.bottom >= currentGroundLevel:\n            tinyBlueOx.bottom = currentGroundLevel\n            vy = 0\n            isJumping = False\n            # Reset fall state\n            isFallingBehindRock = False\n            # Reset object state when landing\n            isOnObject = False\n# **Ensure natural z-depth positioning**\ndef updateLayering():\n    # Let the existing system handle depth naturally\n    tinyBlueOx.z = tinyBlueOx.bottom\n    # Ensure rock maintains correct depth ordering\n    rock.z = rock.bottom\n# **Prevent walking through objects using the original system**\ndef dontWalkThroughRock():\n    if tinyBlueOx.overlaps_with(rock):\n        if tinyBlueOx.bottom > rock.bottom:\n            if tinyBlueOx.bottom - rock.bottom < 2:\n                tinyBlueOx.bottom = rock.bottom + 2\n        else:\n            if rock.bottom - tinyBlueOx.bottom < 2:\n                tinyBlueOx.bottom = rock.bottom - 2\n# **Detect stepping off objects properly and dynamically update ground level**\ndef checkForFallingOffObjects():\n    global isJumping, isOnObject, vy, currentGroundLevel\n    if isOnObject:\n        # If the player's X position is no longer above the rock, they should fall\n        if tinyBlueOx.x < rock.left or tinyBlueOx.x > rock.right:\n            # Start falling\n            isJumping = True\n            isOnObject = False\n            # Reset vertical velocity\n            vy = 0\n            # Set smooth landing height\n            currentGroundLevel = rock.bottom - fallOffset\nisFallingBehindRock = False\nrockMoved = False\noriginalY = 0\noriginalX = 0\npushSpeed = 0\nvy = 0\nisOnObject = False\nisJumping = False\ntinyBlueOx: Sprite = None\ntree: Sprite = None\npushThreshold = 0\nfallOffset = 0\ncurrentGroundLevel = 0\njumpPower = 0\ngravity = 0\nrock: Sprite = None\n# Shared gravity for jumping and falling\ngravity = 2\njumpPower = -14\n# Prevents re-locking on the rock\n# Default ground level, updates dynamically\ncurrentGroundLevel = 87\n# Tracks if the player is standing on an object\n# Offset for smooth landing when walking off the side of the rock\nfallOffset = 4\n# Allows slight misalignment for pushing\npushThreshold = 6\n# Initialize objects\ntree = sprites.create(assets.image(\"\"\"\n        myImage\n        \"\"\"),\n    SpriteKind.physicalObject)\ntree.set_position(44, 87)\ntree.z = tree.bottom\n# Now pushable!\nrock = sprites.create(assets.image(\"\"\"\n    myImage0\n    \"\"\"), SpriteKind.Pushable)\nrock.set_position(118, 87)\nrock.z = rock.bottom\ntinyBlueOx = sprites.create(assets.image(\"\"\"\n    myImage1\n    \"\"\"), SpriteKind.player)\ntinyBlueOx.set_position(108, 86)\ntinyBlueOx.z = 100\n# Allow free movement\ncontroller.move_sprite(tinyBlueOx, 85, 60)\nscene.camera_follow_sprite(tinyBlueOx)\ntiles.set_current_tilemap(tilemap(\"\"\"\n    level2\n    \"\"\"))\ntextSprite = textsprite.create(\"\", 0, 1)\n# Game loop\n\ndef on_on_update():\n    applyJumpPhysics()\n    checkLandingOnObjects()\n    checkForFallingOffObjects()\n    checkForFallingBehindRock()\n    # NEW: Handles rock pushing (fixed downward stop and side pushing)\n    pushRock()\n    dontWalkThroughRock()\n    dontWalkThroughTree()\n    # Ensure correct z-ordering\n    updateLayering()\n    textSprite.set_text(convert_to_text(rock.y))\ngame.on_update(on_on_update)\n","pxt.json":"{\n    \"name\": \"3D beat em up, adapted\",\n    \"description\": \"\",\n    \"dependencies\": {\n        \"device\": \"*\",\n        \"arcade-background-scroll\": \"github:microsoft/arcade-background-scroll#v0.1.2\",\n        \"arcade-text\": \"github:microsoft/arcade-text#v1.3.0\",\n        \"controller\": \"*\"\n    },\n    \"files\": [\n        \"main.blocks\",\n        \"main.ts\",\n        \"README.md\",\n        \"tilemap.g.jres\",\n        \"tilemap.g.ts\",\n        \"images.g.jres\",\n        \"images.g.ts\",